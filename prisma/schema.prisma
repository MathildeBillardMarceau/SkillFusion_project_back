// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ===========================
// ENUMS
// ===========================
enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}
enum Role {
  ADMIN
  INSTRUCTOR
  APPRENTICE
}
enum Status {
  PENDING
  APPROVED
  BANNED
}

// ===========================
// MODEL : Course
// ===========================
model Course {
  id          String  @id @default(uuid(7))   
  title       String  @unique
  slug        String  @unique
  description String?
  image       String?
  level       Level?
  duration    String?
  cost        String?
  material    String?

  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @map("updated_at")

  // FK
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relations : un cours peut avoir plusieurs catégories
  categories  CourseHasCategory[]

  @@map("course")
}

// ===========================
// MODEL : User
// ===========================
model User {
  id          String  @id @default(uuid(7))
  email       String  @unique
  password    String
  firstName   String  @map("first_name")
  lastName    String  @map("last_name")
  role        Role    @default(APPRENTICE)
  status      Status  @default(APPROVED)

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @map("updated_at")

  // Relations : le user peut créer plusieurs cours
  course      Course[] // TODO: à corriger en "courses" pour être bien explicite

  // Refresh token
  refreshToken String?

  @@map("user")
}

// ===========================
// MODEL : Courses
// ===========================

model Category {
  id          String   @id @default(uuid(7))
  name        String   @unique
  description String?
  icon        String?
  color       String?

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @map("updated_at")

  // Relations : 
  courses     CourseHasCategory[]

  @@map("category")
}

model CourseHasCategory{
  // FK
  courseId    String @map("course_id")
  categoryId  String @map("category_id")

  // Relations
  course      Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([courseId, categoryId])

  @@map("course_has_category")
}