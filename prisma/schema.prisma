// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ===========================
// ENUMS
// ===========================
enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  // pas possible de mettre des chiffres dans un enum comme prévu dans la DB, donc il faudra soit 
}
enum Role {
  ADMIN
  INSTRUCTOR
  APPRENTICE
}
enum Status {
  PENDING
  APPROVED
  BANNED
}

// ===========================
// MODEL : Course
// ===========================
model Course {
  id          String  @id @default(uuid(7))   
  title       String  @unique
  slug        String  @unique
  description String?
  image       String?
  level       Level?
  duration    String?
  cost        String?
  material    String?

  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @map("updated_at")
  // @updatedAt permet d'automatiquement modifier le updated_at lorsque l'enregistrement est modifié
  // @Nicolas Mais il faut soit utiliser @updatedAt, soit @default(now())

  // FK
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relation 
  categories CourseHasCategory[]

  @@map("course") // Correspondant entre le model Course et le table course (min) en DB 
}

// ===========================
// MODEL : User
// ===========================
model User {
  id          String  @id @default(uuid(7))
  email       String  @unique
  password    String
  firstName   String  @map("first_name")
  lastName    String  @map("last_name")
  role        Role    @default(APPRENTICE)
  status      Status  @default(APPROVED)

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @map("updated_at")

  // Relations
  course      Course[]

  @@map("user") 
  // pour éviter d'avoir une table user en DB qui est spécifique à PG
  // @Nicolas ENFAIT oui et non, il y a bien une table user dans PG, mais qui se nomme sans les "". 
  // De notre côté, si on veux utiliser un mot-clé déjà utilisé par PG, il suffit de mettre de "".
}

// ===========================
// MODEL : Courses
// ===========================

model Category {
  id          String   @id @default(uuid(7))
  name        String   @unique
  description String?
  icon        String?
  color       String?

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @map("updated_at")

  // relation
  courses     CourseHasCategory[]

  @@map("category")
}

model CourseHasCategory{
  courseId    String @map("course_id")
  categoryId  String @map("category_id")

  course      Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([courseId, categoryId])

  @@map("course_has_category")
}