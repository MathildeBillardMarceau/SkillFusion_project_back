// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ===========================
// ENUMS
// ===========================
enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}
enum Role {
  ADMIN
  INSTRUCTOR
  APPRENTICE
}
enum Status {
  PENDING
  APPROVED
  BANNED
}
enum MediaType {
  IMAGE
  VIDEO
}

// ===========================
// MODEL : User
// ===========================
model User {
  id          String  @id @default(uuid(7))
  email       String  @unique
  password    String
  firstName   String  @map("first_name")
  lastName    String  @map("last_name")
  avatar      String?
  role        Role    @default(APPRENTICE)
  status      Status  @default(APPROVED)

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @map("updated_at")

  // Relations : le user peut créer plusieurs cours
  course      Course[] // TODO: à corriger en "courses" pour être bien explicite

  // Relations : le user peut créer plusieurs messages
  messages    Message[]
  subscribers CourseHasSubscriber[]


  // Refresh token
  refreshToken String?

  @@map("user")
}

// ===========================
// MODEL : Course
// ===========================
model Course {
  id          String  @id @default(uuid(7))   
  title       String  @unique
  slug        String  @unique
  description String?
  image       String?
  level       Level?
  duration    String?
  cost        String?
  material    String?

  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @map("updated_at")

  // FK
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relations : un cours peut avoir plusieurs catégories
  categories  CourseHasCategory[]
  messages    Message[]
  chapters    Chapter[]
  subscribers CourseHasSubscriber[]

  relationPickedCourse      CoursePrerequisitesCourse[] @relation("PickedCourse")
  relationPrereqCourse      CoursePrerequisitesCourse[] @relation("PrereqCourse")

  @@map("course")
}

// ===========================
// MODEL : Chapter
// ===========================
model Chapter {
  id          String   @id @default(uuid(7))
  title       String
  description String?
  text        String?

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @map("updated_at")

  // FK
  courseId    String @map("course_id")
  course      Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  // Relations
  medias       ChapterHasMedia[]


  @@map("chapter")
}

// ===========================
// MODEL : Media
// ===========================
model Media {
  id          String   @id @default(uuid(7))
  url         String   @unique
  type        MediaType

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @map("updated_at")

  // Relations
  chapters    ChapterHasMedia[]

  @@map("media")
}

model ChapterHasMedia{
  // FK
  chapterId   String @map("chapter_id")
  mediaId     String @map("media_id")

  // Relations
  chapter     Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  media       Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@id([chapterId, mediaId])

  @@map("chapter_has_media")
}

// ===========================
// MODEL : Category
// ===========================
model Category {
  id          String   @id @default(uuid(7))
  name        String   @unique
  description String?
  icon        String?
  color       String?

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @map("updated_at")

  // Relations : 
  courses     CourseHasCategory[]

  @@map("category")
}

model CourseHasCategory{
  // FK
  courseId    String @map("course_id")
  categoryId  String @map("category_id")

  // Relations
  course      Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([courseId, categoryId])

  @@map("course_has_category")
}

model CourseHasSubscriber{
  completion  Int

  //FK
  courseId  String @map("course_id")
  userId    String @map("user_id")

  //relations
  course      Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([courseId, userId])

  @@map("course_has_subscriber")

}




// ===========================
// MODEL : Message
// ===========================
model Message {
    id          String  @id @default(uuid(7))
    content     String

    createdAt   DateTime  @default(now()) @map("created_at")
    updatedAt   DateTime  @default(now()) @map("updated_at")

    //relations 
    //un message est fait par un et un seul user mais un user peut faire plusieurs messages (Many to One)
    // FK
    userId      String    @map("user_id")
    user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

    //un message fait partie de un et un seul cours, mais un cours peut avoir plusieurs messages (Many to One)
    courseId    String    @map("course_id")
    course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("message")
}


// ===========================
// MODEL : CoursePrerequisitesCourse 
// ===========================

model CoursePrerequisitesCourse{
  @@id([courseId, prerequisiteId])

  //FK
  courseId        String @map("course_id")
  prerequisiteId  String @map("prerequisite_id")
  
  //Relations (ici on doit préciser quelle relation pour les préciser dans course donc elles sont nommées)
  course        Course @relation("PickedCourse", fields: [courseId], references: [id], onDelete: Cascade)
  prerequisite  Course @relation("PrereqCourse", fields: [prerequisiteId], references: [id], onDelete: Cascade)


@@map("course_prerequisites_course")
}