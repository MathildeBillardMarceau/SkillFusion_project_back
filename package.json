{
	"name": "projet-skillfusion-back",
	"version": "1.0.0",
	"description": "",
	"main": "index.js",
	"type": "module",
	"scripts": {
		"dev": "node --env-file=.env ./src/index.ts --watch",
		"-----": "Pour la DB ---------------------",
		"db:seed": "node --env-file=.env ./src/models/seed.ts",
		"db:migrate:reset": "prisma migrate reset --force",
		"db:reset": "pnpm run db:migrate:reset && pnpm run db:seed",
		"db:sync": "prisma generate && prisma migrate deploy",
		"db:update": "node scripts/migrate.ts",
		"db:init": "pnpm db:sync && pnpm run db:seed"
	},
