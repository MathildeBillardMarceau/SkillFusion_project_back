{
	"name": "projet-skillfusion-back",
	"version": "1.0.0",
	"description": "",
	"main": "index.ts",
	"type": "module",
	"scripts": {
		"======= Pour la prod =======": "========================",
		"build": "tsc",
		"start": "node --env-file=.env dist/src/index.js",
		"docker:start": "pnpm run db:migrate:deploy && node dist/src/index.js",
		"docker:dev:local": "docker compose --env-file .env.local --profile local up",
		"docker:dev:supabase": "docker compose --env-file .env.supabase --profile supabase up",

		"======= Pour la dev =======": "========================",
		"dev": "node --env-file=.env ./src/index.ts --watch",

		"======= Pour la BDD =======": "========================",
		"db:seed": "node --env-file=.env ./src/models/seed.ts",
		"db:migrate:deploy": "prisma migrate deploy",
		"db:generate": "prisma generate",
		"db:migrate:reset": "prisma migrate reset --force",
		"db:deploy": "DATABASE_URL=$DIRECT_URL prisma migrate deploy",
		"db:reset": "pnpm run db:migrate:reset && pnpm run db:seed",
		"db:sync": "prisma generate && prisma migrate deploy",
		"db:update": "node scripts/migrate.ts",
		"db:init": "pnpm db:sync && pnpm run db:seed",

		"======= Pour les tests =======": "========================",
		"test": "node --test",
		"test:integration": "NODE_ENV=test node --env-file=.env.test --import ./tests/setup.ts --test tests/**/*.test.ts",
		"docker:test:integration": "docker compose --env-file .env.test run --rm -e NODE_ENV=test skillfusion-gql-api pnpm test:integration"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/O-clock-Copenhague/projet-skillfusion-back.git"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/O-clock-Copenhague/projet-skillfusion-back/issues"
	},
	"homepage": "https://github.com/O-clock-Copenhague/projet-skillfusion-back#readme",
	"dependencies": {
		"@apollo/server": "^5.2.0",
		"@as-integrations/express5": "^1.1.2",
		"@prisma/adapter-pg": "^7.1.0",
		"@prisma/client": "^7.1.0",
		"argon2": "^0.44.0",
		"cors": "^2.8.5",
		"express": "^5.2.1",
		"graphql": "^16.12.0",
		"graphql-scalars": "^1.25.0",
		"jsonwebtoken": "^9.0.3",
		"pg": "^8.16.3",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.6",
		"@types/express": "^5.0.6",
		"@types/node": "^24.10.1",
		"@types/pg": "^8.15.6",
		"dotenv": "^17.2.3",
		"prisma": "^7.1.0",
		"ts-node": "^10.9.2",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	}
}
